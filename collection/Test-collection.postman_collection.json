      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json()\r",
              "switch (pm.response.code)\r",
              "\r",
              "{\r",
              "    case 200:\r",
              "        pm.environment.set(\"auth_key\",response.auth_key)\r",
              "        pm.environment.set(\"auth_expire\", Date.now() + response.expires_in *1000 )\r",
              "        pm.environment.set(\"user_balance\",response.account.balance)\r",
              "        console.log(\"hello\")\r",
              "        break;\r",
              "\r",
              "    default:\r",
              "        console.log(\"Unexpected error code found\")\r",
