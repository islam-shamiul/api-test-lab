    {
      "name": "prevalidation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"pre_trx_id\", response.pre_trx_id);\r",
              "pm.environment.set(\"charge\", response.charge);\r",
              "pm.environment.set(\"total_amount\", response.total_amount);\r",
              "\r",
              "// Eligibility\r",
              "pm.test(\"User eligible for transaction\", function() {\r",
              "    pm.expect(response.eligible).to.eql(true);\r",
              "});\r",
              "\r",
              "// Charge validation\r",
              "pm.test(\"Charge calculated\", function() {\r",
              "    pm.expect(response.charge).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "// Total validation\r",
              "pm.test(\"Total amount correct\", function() {\r",
              "    pm.expect(response.total_amount).to.eql(response.amount + response.charge);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let authKey = pm.environment.get(\"auth_key\");\r",
              "let expiry = pm.environment.get(\"auth_expire\");\r",
              "\r",
              "pm.test(\"auth key validation\",function(){\r",
              "\r",
              "    if (!authKey || Date.now() > expiry) {\r",
              "    postman.setNextRequest(\"Login\");\r",
              "    }\r",
              "})\r",
              "\r",
              "\r",
              "let amount = Number(pm.environment.get(\"trx_amount\"));\r",
              "let balance = Number(pm.environment.get(\"balance\"));\r",
              "\r",
              "// Fraud check\r",
              "if (amount > 5000) {\r",
              "    throw new Error(\"FRAUD_DETECTED\");\r",
              "}\r",
              "\r",
              "// Invalid\r",
              "if (amount <= 0) {\r",
              "    throw new Error(\"INVALID_AMOUNT\");\r",
              "}\r",
              "\r",
              "// Balance check\r",
              "if (amount > balance) {\r",
              "    throw new Error(\"INSUFFICIENT_BALANCE\");\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
